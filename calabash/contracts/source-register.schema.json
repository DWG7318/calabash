{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Calabash Source Register",
  "type": "object",
  "required": [
    "sources"
  ],
  "properties": {
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "source_id",
          "title",
          "source_class",
          "authority_level",
          "freshness_status",
          "verified"
        ],
        "properties": {
          "source_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "location": {
            "type": [
              "string",
              "null"
            ]
          },
          "hash": {
            "type": [
              "string",
              "null"
            ]
          },
          "source_class": {
            "type": "array",
            "items": {
              "enum": [
                "OWNER_AUTHORITY",
                "APPROVED_NORMATIVE",
                "OBSERVED_REALITY",
                "USER_EVIDENCE",
                "ENGINEERING_EVIDENCE",
                "HISTORICAL_DECISION",
                "EXTERNAL_CONSTRAINT",
                "AI_INFERENCE"
              ]
            }
          },
          "authority_level": {
            "enum": [
              "PRIMARY",
              "SECONDARY",
              "DESCRIPTIVE",
              "INFERENTIAL"
            ]
          },
          "freshness_status": {
            "enum": [
              "CURRENT",
              "STALE",
              "UNKNOWN"
            ]
          },
          "verified": {
            "type": "boolean"
          },
          "claims_supported": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "claims_contradicted": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "observed_at": {
            "type": [
              "string",
              "null"
            ]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
